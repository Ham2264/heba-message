<!DOCTYPE html>
<html lang="ar">
<head>
<meta charset="UTF-8">
<title>رسالة لهِبة</title>

<style>
body {
  margin: 0;
  font-family: Arial;
  background: radial-gradient(circle, #1a1a1a, #000);
  color: white;
  text-align: center;
  overflow: hidden;
}

/* البداية */
#start {
  margin-top: 120px;
  animation: fadeIn 1s;
}

/* سؤال */
#question {
  margin-top: 120px;
  font-size: 22px;
  animation: fadeUp 0.6s ease;
}

/* أزرار */
.option-btn {
  display: block;
  margin: 10px auto;
  padding: 12px 20px;
  border-radius: 25px;
  border: none;
  background: rgba(255,255,255,0.1);
  color: white;
  cursor: pointer;

  animation: pop 0.5s ease;
  transition: 0.3s;
}

.option-btn:hover {
  background: #ff4d6d;
  transform: scale(1.1);
  box-shadow: 0 0 15px #ff4d6d;
}

/* رسالة */
.message-box {
  margin-top: 100px;
  padding: 25px;
  border-radius: 25px;
  width: 65%;
  margin-left: auto;
  margin-right: auto;
  border: 2px solid #ff6f91;
  background: rgba(255, 105, 135, 0.1);
  box-shadow: 0 0 25px rgba(255, 100, 150, 0.4);
  animation: fadeIn 1s;
}

/* أنيميشن */
@keyframes fadeIn {
  from {opacity:0;}
  to {opacity:1;}
}

@keyframes fadeUp {
  from {opacity:0; transform: translateY(20px);}
  to {opacity:1; transform: translateY(0);}
}

@keyframes pop {
  0% { transform: scale(0.5); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}
</style>
</head>

<body>

<!-- البداية -->
<div id="start">
  <h1>هِبة… 💌</h1>
  <p>عندي لك شي بسيط</p>
  <button onclick="startQuiz()" class="option-btn">ابدئي</button>
</div>

<!-- الأسئلة -->
<div id="quiz" style="display:none;">
  <h2 id="question"></h2>
  <div id="options"></div>
</div>

<!-- الرسالة -->
<div id="final" style="display:none;">
  <div class="message-box">
    <h2>💖 رسالة لك يا هِبة</h2>
    <p id="text"></p>
  </div>
</div>

<script>

/* أسئلة كثيرة */
const questions = [
  {
    q: "وش أكثر شي يريح هِبة؟",
    options: ["الهدوء 🌙", "الضحك 😂", "الكلام مع شخص قريب 💬"]
  },
  {
    q: "لو يومها كان سيء، وش تحتاج؟",
    options: ["أحد يسمع لها 🤍", "أحد يضحكها ✨", "أحد يهتم فيها 🌸"]
  },
  {
    q: "وش تحب هِبة أكثر؟",
    options: ["الاهتمام 💖", "الصدق 🌿", "الناس الطيبة ☁️"]
  },
  {
    q: "كيف تحب تتعامل معها؟",
    options: ["بلطف 🤍", "بحنان 💖", "كأنها أخت 🌸"]
  },
  {
    q: "لو وصفتها بكلمة؟",
    options: ["لطيفة ✨", "مميزة 💫", "قريبة للقلب ❤️"]
  }
];

let current = 0;

/* بدء */
function startQuiz(){
  document.getElementById("start").style.display = "none";
  document.getElementById("quiz").style.display = "block";
  showQuestion();
}

/* عرض سؤال */
function showQuestion(){
  let q = questions[current];

  document.getElementById("question").innerHTML = q.q;

  let html = "";
  q.options.forEach(opt => {
    html += `<button class="option-btn" onclick="next()">${opt}</button>`;
  });

  document.getElementById("options").innerHTML = html;
}

/* الانتقال */
function next(){
  current++;

  if(current >= questions.length){
    showFinal();
  } else {
    showQuestion();
  }
}

/* الرسالة */
function showFinal(){
  document.getElementById("quiz").style.display = "none";
  document.getElementById("final").style.display = "block";

  let msg = `هِبة…
وجودك مو شي عادي 🤍

أنتِ قريبة لقلبي بطريقة ما تنشرح،
وأشوفك كأنك أختي 🌸

أهتم فيك بدون ما أحس،
وأفرح لك من قلبي…

وأتمنى دايم أكون الشي
اللي يريحك 💫`;

  typeText(msg);
}

/* كتابة تدريجية */
let i = 0;
function typeText(msg){
  if(i < msg.length){
    document.getElementById("text").innerHTML += msg.charAt(i);
    i++;
    setTimeout(()=>typeText(msg), 35);
  }
}

</script>

</body>
</html>
